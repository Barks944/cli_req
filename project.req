          "reason": null
        }
      ],
      "id": "REQ-0075",
      "kind": "Functional",
      "links": [],
      "priority": "Could",
      "rationale": "A single project.req becomes a merge hotspot and produces noisy diffs once a project grows past a few hundred requirements. A directory layout localises edits to the file that changed.",
      "statement": "The CLI shall support an optional directory-backed storage layout, with one file per requirement and a top-level index, that preserves the integrity and atomicity guarantees of the single-file format.",
      "status": "Draft",
      "tags": [
        "storage",
        "scaling"
      ],
