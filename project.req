      "links": [
        {
          "kind": "Mitigates",
          "target": "HAZ-0002"
        }
      ],
      "safe_state": "every Verified requirement is classified as genuine, exempt, stale or ungated; a fabricated, shallow or exemption-based claim is visibly flagged and any dossier is revertible to ungated, so non-genuine verification cannot masquerade as trustworthy",
      "status": "Allocated",
      "tags": [],
      "title": "Verification provenance distinguishes genuine validation from non-genuine claims",
      "updated": "2026-06-13T07:01:13.869702700Z"
    }
