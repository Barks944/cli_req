      ],
      "id": "REQ-0007",
      "kind": "Functional",
      "links": [],
      "priority": "Should",
      "rationale": "Weasel words turn requirements into unverifiable wishes; surfacing them at write time is cheaper than discovering them in QA.",
      "statement": "The system shall emit a warning for every occurrence of a known weasel word (etc, and/or, user-friendly, fast, robust, TBD and the rest of the configured list) inside a statement.",
      "status": "Implemented",
      "tags": [
        "validation"
      ],
      "title": "Warn on weasel words in statements",
      "updated": "2026-05-17T07:14:36.815596400Z"
    },
