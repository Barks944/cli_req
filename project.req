          "content_hash": "364846e5bdf4b869a93451ddea3292079110846b2df07be8df4782fa84244e45",
          "kind": "Automated",
          "linked_files": [
            ".\\CHANGELOG.md",
            ".\\src\\storage.rs",
            ".\\tests\\forward_compat.rs"
          ],
          "notes": "cargo test: 2 pass / 0 fail / 0 ignored — req_0141_save_refused_when_file_schema_rev_is_newer, req_0141_missing_schema_rev_is_treated_as_zero",
          "outcome": "Pass"
        },
        {
