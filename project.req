      "id": "REQ-0006",
      "kind": "Functional",
      "links": [],
      "priority": "Must",
      "rationale": "Normative modal verbs are the universal marker of a real requirement; their absence almost always means the text is descriptive rather than prescriptive.",
      "statement": "The system shall reject any requirement whose statement does not contain at least one of the modal verbs shall, must, should or will.",
      "status": "Implemented",
      "tags": [
        "validation"
      ],
