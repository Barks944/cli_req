      "id": "REQ-0019",
      "kind": "Constraint",
      "links": [],
      "priority": "Must",
      "rationale": "Direct reads encourage agents to skip validation; direct writes break integrity. This is the project's load-bearing constraint.",
      "statement": "Agents shall interact with project.req exclusively through req subcommands or the req mcp interface and shall never read or write the file with general-purpose tools.",
      "status": "Verified",
      "tags": [
