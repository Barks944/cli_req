      ],
      "id": "REQ-0027",
      "kind": "Functional",
      "links": [],
      "priority": "Should",
      "rationale": "The CLI cannot itself prove authenticity; surfacing git signature state in one place gives reviewers and auditors a defensible provenance trail without adding a parallel PKI.",
      "statement": "The system shall walk git log --follow on the .req file and shall print, for each commit, the signature status (good, bad, expired, no-signature) and signer reported by git.",
      "status": "Implemented",
      "tags": [
        "integration",
        "git",
        "audit"
      ],
      "title": "Report git signature status per commit via req audit",
